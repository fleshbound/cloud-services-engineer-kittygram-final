# Имя базы данных
POSTGRES_DB=kittygram

# Имя пользователя БД
POSTGRES_USER=kittygram_user

# Пароль к БД
POSTGRES_PASSWORD=kittygram_password

# Имя Хоста.
# Адрес, по которому Django будет соединяться с БД (имя контейнера внутри сети compose, где хранится БД).
DB_HOST=postgres

# Порт соединения к БД
DB_PORT=5432

SECRET_KEY=django-insecure-cg6*%6d51ef8f#4!r3*$vmxm4)abgjw8mo!4y-q*uq1!4$-89$

DEBUG=False

# Список разрешённых хостов, чтобы проект запустился через внешний интерфейс
# и для доступа к приложению по внутреннему интерфейсу, например:
ALLOWED_HOSTS=250.250.250.250 127.0.0.1 localhost kittygram.ru backend